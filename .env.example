# ============================================================
# ARQUIVO DE CONFIGURAÇÃO LOCAL (.env)
# ============================================================
# AVISO: Este arquivo contém senhas e dados sensíveis.
# NUNCA commitar este arquivo no repositório!
# Use como modelo: renomeie .env.example para .env e preencha.
# ============================================================

# SERVIDOR
PORT=3001
NODE_ENV=development

# BANCO DE DADOS (OBRIGATÓRIO)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=sua_senha_mysql_aqui
DB_NAME=estoque_db
DB_PORT=3306

# CORS (OPCIONAL - padrão: todas as origens)
CORS_ORIGIN=*

# E-MAIL 2FA (OPCIONAL - padrão: desabilitado)
# Para funcionar, OBRIGATORIAMENTE:
# 1. Crie uma conta Gmail dedicada
# 2. Ative 2FA na conta Google
# 3. Gere uma App Password em: https://myaccount.google.com/apppasswords
# 4. Preencha MAIL_USER e MAIL_PASS com os valores gerados
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=seu_email@gmail.com
MAIL_PASS=sua_app_password_16_caracteres
MAIL_FROM="IntelliStock <seu_email@gmail.com>"

# URL DA APLICAÇÃO (OPCIONAL - padrão: http://localhost:PORT)
# Usado para gerar links de redefinição de senha
APP_URL=http://localhost:3001
