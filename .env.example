node server.js# ============================================================
# ARQUIVO DE CONFIGURAÇÃO LOCAL (.env)
# ============================================================
# AVISO: Este arquivo contém senhas e dados sensíveis.
# NUNCA commitar este arquivo no repositório!
# Use como modelo: renomeie .env.example para .env e preencha.
# ============================================================

# SERVIDOR
PORT=3001
NODE_ENV=development

# BANCO DE DADOS (OBRIGATÓRIO)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=sua_senha_mysql_aqui
DB_NAME=estoque_db
DB_PORT=3306

# CORS (OPCIONAL - padrão: todas as origens)
CORS_ORIGIN=*

# E-MAIL 2FA (OPCIONAL - padrão: desabilitado)
# Para funcionar, OBRIGATORIAMENTE:
# 1. Crie uma conta Gmail dedicada
# 2. Ative 2FA na conta Google
# 3. Gere uma App Password em: https://myaccount.google.com/apppasswords
# 4. Preencha MAIL_USER e MAIL_PASS com os valores gerados
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=seu_email@gmail.com
MAIL_PASS=sua_app_password_16_caracteres
MAIL_FROM="IntelliStock <seu_email@gmail.com>"

# ALERTAS DE ESTOQUE (OPCIONAL)
# Envia alertas para o dono da conta + e-mails abaixo (separados por virgula, ponto e virgula ou espaco)
ALERT_EMAILS=

# URL DA APLICAÇÃO (OPCIONAL - padrão: http://localhost:PORT)
# Usado para gerar links de redefinição de senha e URLs de retorno do Mercado Pago
APP_URL=http://localhost:3001

# ACESSO LIVRE PARA DESENVOLVEDORES (OPCIONAL)
# Lista de e-mails liberados sem assinatura ativa (separar por vírgula, ponto e vírgula ou espaço)
# Exemplo: DEV_ACCESS_EMAILS=dev1@empresa.com,dev2@empresa.com
DEV_ACCESS_EMAILS=

# MERCADO PAGO (OBRIGATÓRIO para pagamentos)
# Acesse https://www.mercadopago.com.br/developers e crie um aplicativo
# Use aqui o Access Token oficial de PRODUÇÃO para processar pagamentos reais
MP_ACCESS_TOKEN=seu_access_token_mercado_pago_aqui
