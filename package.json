{
  "name": "estoque-management",
  "version": "1.0.0",
  "description": "Sistema de gerenciamento de estoque com Node.js e Express",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "setup-db": "node setup-db.js",
    "setup:db": "node setup-db.js",
    "start:tudo": "npm run setup:db && npm run dev",
    "start:all": "npm install && npm run start:tudo"
  },
  "keywords": ["estoque", "inventory", "management"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "mysql2": "^3.6.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "nodemon": "^2.0.22"
  }
}
